# ============================================================
# MULTI-AGENT SYSTEM — CONFIGURATION REFERENCE
# ============================================================
# This file documents every configuration key accepted by the
# application. It is committed to git and contains safe defaults.
#
# To override locally: copy values to .env (gitignored)
# In production: set process environment variables directly
# ============================================================

# Application identity
APP_NAME=multiagent
APP_ENV=development

# --- OBSERVABILITY ---
# Console stream
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_LEVEL=WARNING

# Human-readable log file (.log) — disabled by default
LOG_HUMAN_FILE_ENABLED=true
LOG_HUMAN_FILE_LEVEL=INFO

# JSON Lines log file (.jsonl) — disabled by default
LOG_JSON_FILE_ENABLED=true
LOG_JSON_FILE_LEVEL=DEBUG

# Shared
LOG_DIR=logs
LOG_TRACE_LLM=true           # JSONL file only — console and .log never receive trace events
# EXPERIMENT=                  # optional label in filenames; override with --experiment flag

# Hello World test values
GREETING_MESSAGE=Hello from multiagent default config
# GREETING_SECRET=          # REQUIRED. No default. Must be set in .env, never committed.

# --- LLM ---
# OPENROUTER_API_KEY=          # REQUIRED. No default. Must be set in .env, never committed.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# google/gemini-3-flash-preview
# google/gemini-3.1-flash-lite-preview
# google/gemini-2.5-flash-lite
# google/gemini-2.5-flash
# x-ai/grok-4.20-beta
# x-ai/grok-4.1-fast
# anthropic/claude-opus-4.6
# anthropic/claude-sonnet-4.6
# anthropic/claude-haiku-4.5
# minimax/minimax-m2.5
# stepfun/step-3.5-flash:free
# deepseek/deepseek-v3.2
# moonshotai/kimi-k2.5
# openai/gpt-oss-120b
# openai/gpt-5-nano
# openai/gpt-5.4
# openai/gpt-4o-mini
# arcee-ai/trinity-large-preview:free
# 
LLM_MODEL=google/gemini-2.5-flash
LLM_MAX_TOKENS=102400
LLM_TIMEOUT_SECONDS=30.0

# --- PROMPTS ---
PROMPTS_DIR=prompts

# --- MCP TOOLS ---
MCP_CONFIG_PATH=agents.mcp.json
MCP_SECRETS_PATH=agents.mcp.secrets.json

# --- AGENT WIRING ---
AGENTS_CONFIG_PATH=agents.toml

# --- TERMINATION ---
# Loop detection: halt when agent sends to itself this many consecutive times.
# 0 = disabled.
AGENT_LOOP_DETECTION_THRESHOLD=3

# Max messages per thread: halt dispatch when thread reaches this count.
# 0 = unlimited.
AGENT_MAX_MESSAGES_PER_THREAD=0

# --- TRANSPORT ---
# Options: sqlite | terminal
TRANSPORT_BACKEND=sqlite
SQLITE_DB_PATH=data/agents.db
SQLITE_POLL_INTERVAL_SECONDS=10.0
CHAT_REPLY_TIMEOUT_SECONDS=120

# --- CHECKPOINTER ---
CHECKPOINTER_DB_PATH=data/checkpoints.db
